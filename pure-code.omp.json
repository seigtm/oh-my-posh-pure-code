{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#81A1C1",
                    "options": {
                        "style": "full"
                    },
                    "style": "plain",
                    "template": "{{ .Path }} ",
                    "type": "path"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#6C6C6C",
                    "options": {
                        "branch_ahead_icon": "<#88C0D0>\u21e1 </>",
                        "branch_behind_icon": "<#88C0D0>\u21e3 </>",
                        "branch_icon": "",
                        "fetch_status": true
                    },
                    "style": "plain",
                    "template": "git:{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} dirty:{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} staged:{{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} stash:{{ .StashCount }}{{ end }} ",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#A3BE8C",
                    "options": {
                        "style": "austin",
                        "threshold": 1000,
                        "always_enabled": false
                    },
                    "style": "plain",
                    "template": " {{ .FormattedMs }} ",
                    "type": "executiontime"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "#B48EAD",
                    "foreground_templates": [
                        "{{ if gt .Code 0 }}#BF616A{{ end }}"
                    ],
                    "options": {
                        "always_enabled": true
                    },
                    "style": "plain",
                    "template": "\u276f ",
                    "type": "status"
                }
            ],
            "type": "prompt"
        }
    ],
    "console_title_template": "{{if .Root}}(Admin){{end}} {{.PWD}}",
    "secondary_prompt": {
        "foreground": "#6C6C6C",
        "template": ">> "
    },
    "version": 4
}